#!/usr/bin/env bash
#
# Wait for the ECS service to reach a stable state after deployment.
# Uses the AWS API directly — does not require network access to the public endpoint.

cluster="${APP_ENV}-easi-app"
service="easi-app"

echo "Waiting for ECS service $service on cluster $cluster to stabilize..." 1>&2
aws ecs wait services-stable --cluster "$cluster" --services "$service"
